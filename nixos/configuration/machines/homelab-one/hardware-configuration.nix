    fsType = "btrfs";
    options = [ "subvol=sub1" ];
  };

  fileSystems."/snapraid/disk2" = {
    device = "/dev/disk/by-uuid/ad88c745-5fa0-459d-ae1d-2cae0e2d634a";
    fsType = "btrfs";
    options = [ "subvol=sub1" ];
  };

