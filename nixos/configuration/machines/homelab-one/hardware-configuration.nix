    device = "/dev/disk/by-uuid/85042328-41b8-47f1-9f7b-fa3d8eb68991";
    fsType = "btrfs";
    options = [ "subvol=parity" ];
  };

  swapDevices = [
    { device = "/dev/disk/by-uuid/6f84f967-d26d-4faa-b7b9-531ee0ed057e"; }
